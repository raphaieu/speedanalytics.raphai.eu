BBTIPS_APP_URL=https://app.bbtips.com.br
BBTIPS_SPEEDWAY_URL=https://app.bbtips.com.br/speedway/horarios
STORAGE_STATE_PATH=./storage/bbtips-storage-state.json
PAYLOAD_DIR=./storage/payloads
STATUS_FILE=./storage/collector-status.json
RACES_INDEX_FILE=./storage/races-index.json
RUNS_FILE=./storage/collector-runs.json
LOG_FILE=./storage/collector.log
HEALTH_CHECK_INTERVAL_MS=60000
STALE_THRESHOLD_MS=300000
HEADLESS=true
LOGIN_TIMEOUT_MS=300000
SPEEDWAY_FILTRO_EXIBICAO=Odd_Todas
SPEEDWAY_HORAS=Horas48
SPEEDWAY_FUTURO=true

