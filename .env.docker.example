# Deploy manual Docker (legado) — produção via Coolify: .env.coolify.example
# Copie para .env na VPS: cp .env.docker.example .env
# Gere APP_KEY: docker compose run --rm app php artisan key:generate
#
# Este arquivo assume compose com bind mounts e serviços app/nginx separados.
# O docker-compose.yml atual é orientado a Coolify (sem bind mounts).

APP_NAME="Speedway Analytics"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://speedanalytics.raphai.eu

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_LEVEL=info

# MySQL — host "mysql" é o nome do serviço no docker-compose
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=speedanalytics
DB_USERNAME=speedanalytics
DB_PASSWORD=

MYSQL_ROOT_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"

# Token compartilhado com collector/.env (header x-speedway-collector-token)
SPEEDWAY_COLLECTOR_TOKEN=

# Timing / corridas (ver .env.coolify.example)
# SPEEDWAY_TIMEZONE=America/Sao_Paulo
# SPEEDWAY_RACE_SCHEDULE_OFFSET_HOURS=4
# SPEEDWAY_PENDING_STALE_BUFFER_MINUTES=8
# SPEEDWAY_PENDING_EXTERNAL_ID_LAG=80
# SPEEDWAY_RACE_LIVE_WINDOW_MINUTES=4
# SPEEDWAY_COLLECTOR_PAYLOAD_STALE_SECONDS=120
# SPEEDWAY_RECONCILE_LOOKBACK_HOURS=24
# SPEEDWAY_RECONCILE_SCAN_LIMIT=200

# Porta HTTP exposta pelo nginx (80 padrão; use outra se houver proxy na frente)
HTTP_PORT=80

# COLLECTOR_STATUS_PATH=  # padrão: {base}/collector/storage/collector-status.json
