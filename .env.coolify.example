# Variáveis para configurar no Coolify (Environment Variables do resource Docker Compose)
# Gere APP_KEY localmente: php artisan key:generate --show

APP_NAME=Speedway Analytics
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://speedanalytics.raphai.eu

LOG_LEVEL=info

DB_DATABASE=speedanalytics
DB_USERNAME=speedanalytics
DB_PASSWORD=
MYSQL_ROOT_PASSWORD=

# Token compartilhado entre Laravel e collector (header x-speedway-collector-token)
SPEEDWAY_COLLECTOR_TOKEN=

# BB Tips — collector
BBTIPS_APP_URL=https://app.bbtips.com.br
BBTIPS_SPEEDWAY_URL=https://app.bbtips.com.br/speedway/horarios
SPEEDWAY_FILTRO_EXIBICAO=Odd_Todas
SPEEDWAY_HORAS=Horas48
SPEEDWAY_FUTURO=true

# Collector — freshness / captura (defaults alinhados ao código)
HEALTH_CHECK_INTERVAL_MS=30000
SPEEDWAY_COLLECTOR_INTERVAL_MS=30000
PAYLOAD_STALE_THRESHOLD_MS=120000
RELOAD_THRESHOLD_MS=300000
# Legado (não usado pelo health check atual; preferir PAYLOAD_STALE_THRESHOLD_MS)
STALE_THRESHOLD_MS=120000

# Timing / corridas — Laravel (web, queue, scheduler)
SPEEDWAY_TIMEZONE=America/Sao_Paulo
SPEEDWAY_RACE_SCHEDULE_OFFSET_HOURS=4
SPEEDWAY_PENDING_STALE_BUFFER_MINUTES=8
SPEEDWAY_PENDING_EXTERNAL_ID_LAG=80
SPEEDWAY_RACE_LIVE_WINDOW_MINUTES=4

# Status do collector na API
SPEEDWAY_COLLECTOR_PAYLOAD_STALE_SECONDS=120

# Reconciliação + liquidação demo (scheduler: serviço schedule:work no compose)
SPEEDWAY_RECONCILE_LOOKBACK_HOURS=24
SPEEDWAY_RECONCILE_SCAN_LIMIT=200

# COLLECTOR_STATUS_PATH=  # padrão: {base}/collector/storage/collector-status.json (volume compartilhado)
