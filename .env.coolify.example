# Variáveis para configurar no Coolify (Environment Variables do resource Docker Compose)
# Gere APP_KEY localmente: php artisan key:generate --show

APP_NAME=Speedway Analytics
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://speedanalytics.raphai.eu

LOG_LEVEL=info

DB_DATABASE=speedanalytics
DB_USERNAME=speedanalytics
DB_PASSWORD=
MYSQL_ROOT_PASSWORD=

# Token compartilhado entre Laravel e collector (header x-speedway-collector-token)
SPEEDWAY_COLLECTOR_TOKEN=

# Opcional — collector
# BBTIPS_APP_URL=https://app.bbtips.com.br
# HEALTH_CHECK_INTERVAL_MS=60000
# STALE_THRESHOLD_MS=300000
